package components

// create a list of navigation items

type NavItem struct {
	label string
	url   string
}

var navItems = []NavItem{
	{
		label: "Home", url: "/",
	},
	{
		label: "Session", url: "/session",
	},
}

templ Footer() {
	<div class="flex justify-around fixed bottom-0 left-0 w-full bg-gray-200 p-4" hx-target="#main">
		for _, item := range navItems {
			<div hx-push-url="true" hx-get={ string(templ.URL(item.url)) }>{ item.label }</div>
		}
	</div>
}
